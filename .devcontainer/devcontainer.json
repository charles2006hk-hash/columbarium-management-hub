{
  "name": "columbarium-management-hub",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:20",
  "postCreateCommand": "npm install -g firebase-tools vercel turbo && npm install",
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      },
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "tamasfe.even-better-toml",
        "dsznajder.es7-react-js-snippets"
      ]
    }
  },
  "forwardPorts": [3000, 3001, 4000, 8080, 5001],
  "portsAttributes": {
    "3000": { "label": "Web App", "onAutoForward": "notify" },
    "3001": { "label": "Admin App", "onAutoForward": "notify" },
    "4000": { "label": "Firebase Emulator UI", "onAutoForward": "silent" }
  }
}